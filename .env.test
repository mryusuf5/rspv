# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999

# Override .env.local: tests use an isolated SQLite file.
# (Doctrine's dbname_suffix has no effect on SQLite, hence this explicit URL.)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/cache/test.db"
